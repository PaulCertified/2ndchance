# Public site URL (HTTPS, no trailing slash) — used for sitemap.xml & robots.txt on build
VITE_SITE_URL=https://www.example.com

# Required for lead form: Formspree form ID from https://formspree.io/ (path after /f/)
VITE_FORMSPREE_FORM_ID=

# Optional: override agent phone on the post-submit screen (E.164 for tel:)
# VITE_AGENT_PHONE_DISPLAY=(615) 555-1234
# VITE_AGENT_PHONE_TEL=+16155551234
